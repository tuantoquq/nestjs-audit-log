{
  "name": "@nestjs-audit-log/core",
  "version": "1.0.0",
  "description": "Decorator-based audit logging for NestJS with user-defined schemas.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tuantoquq/nestjs-audit-log.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/tuantoquq/nestjs-audit-log/tree/main/packages/core#readme",
  "bugs": "https://github.com/tuantoquq/nestjs-audit-log/issues",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
   "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint src test",
    "test": "jest --config jest.config.ts",
    "test:int": "jest --config jest.config.ts --runInBand --testMatch '**/*.int-spec.ts' --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0",
    "rxjs": "^7.8.0"
  },
  "dependencies": {
    "deep-diff": "^1.0.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@types/deep-diff": "^1.0.5"
  }
}
