{
  "name": "@nestjs-audit-log/typeorm",
  "version": "1.0.0",
  "description": "TypeORM storage adapter for @nestjs-audit-log/core.",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint src test",
    "test": "jest --config jest.config.ts",
    "test:int": "jest --config jest.config.ts --runInBand --testMatch '**/*.int-spec.ts'",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@nestjs-audit-log/core": "^1.0.0",
    "@nestjs/typeorm": "^11.0.0",
    "typeorm": "^0.3.28"
  },
  "dependencies": {
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@nestjs-audit-log/core": "workspace:*",
    "@testcontainers/postgresql": "^11.14.0",
    "pg": "^8.20.0"
  }
}
